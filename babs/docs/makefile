docs_dir=.
include shared.mk

.SILENT:

specfiles = $(wildcard *.spec)
samplesheet=$(wildcard $(samplesheet_fname).csv)
configs = $(wildcard *.config)
metadata = $(wildcard $(experiment_table).csv)

.PHONY: run clean

include settings.mk

# Logic is to use existence of non-empty report.err as a flag for
# problem.  On any run, put any problems in tmp.err, and at the end
# we reflect anything generated into the report.err _and_ make sure
# tmp.err is no longer present to allow future runs a clean state.


run: $(specfiles) check-samplesheet $(configs) $(metadata) ## Basic check that the contents of the docs folder conforms to requirements
	$(GIT) commit -m "Adding files generated by a docs run" || echo "No docs files needed adding"
	[ -n "$(specfiles)" ] || echo "No *.spec files in the docs directory" | tee -a tmp.err
	[ -n "$(configs)" ] || echo "No *.config files in the docs directory" | tee -a tmp.err
	[ -n "$(metadata)" ] || echo "No $(experiment_table).csv in the docs directory" | tee -a tmp.err
	[ -f tmp.err ] && mv tmp.err report.err || rm -f report.err
	[ -f tmp.log ] && mv tmp.log report.log || touch report.log
	[ ! -s report.err ]

ifneq ($(specfiles),)
$(specfiles) : 
	[[ -s "$@" ]] || { echo "$@ is empty" | tee -a tmp.err; }
endif

limsid=$(subst asf-,,$(subst lims-,,$(setting_Lims)))
lab-sci=$(word 2,$(subst /projects/, ,$(dir $(setting_Path))))

fqprefix?=/nemo/stp/babs/inputs/sequencing/data
fqfiles=$(wildcard $(fqprefix)/$(lab-sci)$(limsid)/primary_data/*/fastq/*_R1_001.fastq.gz)

.PHONY: check-samplesheet
check-samplesheet: $(samplesheet_fname).csv
	head -1 $< | grep -q "^sample,fastq_1,fastq_2" || { echo "$< has incorrect header" | tee -a tmp.err ;}
	[ $(word 1,$(shell wc -l $<)) -ge 2 ] || { echo "$< has only one line" | tee -a tmp.err ;}


$(samplesheet_fname).csv : $(fqfiles)
ifeq ($(fqfiles),)
	echo "Couldn't find fastq files in " $(fqprefix)/$(lab-sci)$(limsid)/primary_data " Perhaps try setting fqprefix or fqfiles" | tee -a tmp.err
else
	echo "sample,fastq_1,fastq_2" > $@
	for r1 in $(fqfiles); do \
	  echo -n $$(basename $$r1) | sed 's/_.*/,/' >> $@ ;\
	  echo -n "$$r1," >> $@ ;\
	  r2=`echo $$r1 | sed 's/_R1_/_R2_/'` ;\
	  if [ -f "$$r2" ];\
	    then echo $$r2 >> $@ ;\
	    else echo "" >> $@ ;\
	  fi ;\
	done
	$(GIT) add $@
endif


ifeq ($(configs),)
$(error No config files in the docs directory)
else
$(configs) :
	[[ -s "$@" ]] || { echo "$@ is empty" | tee -a tmp.err; }
endif


settings.mk:
	if [ -f ../../.babs ];\
	then sed '1d; /^\s*$/d; s/^[[:space:]]*/setting_/; s/: /=/' ../../.babs > $@ ;\
	else touch settings.mk ;\
	fi

ifneq ($(metadata),)
$(metadata) :
	[[ -s "$@" ]] || { echo "$@ is empty" | tee -a tmp.err; }
	head -1 $@ | grep -q "^$(metadata_id_column)" || { echo "$(metadata) does not start with a column named $(metadata_id_column)" | tee -a tmp.err; }
	head -1 $@ | grep -q "$(metadata_id_column),sample_label" || echo "$(metadata) does not have sample_label column after $(metadata_id_column) - the first unduplicated column after $(metadata_id_column), or $(metadata_id_column) itself will be used as a label" | tee -a tmp.log
endif

clean:
	rm -f report.err report.log

