RENV_PATHS_ROOT = /camp/stp/babs/working/software/renv
SINGULARITY_ROOT= /camp/stp/babs/working/bioinformatics/software/singularity
TEMPLATE_DIR = /camp/stp/babs/working/bioinformatics/templates
SCRATCH_DIR = /camp/stp/babs/scratch/bioinformatics/projects/${babsid}/
NXF_SINGULARITY_CACHEDIR = /camp/apps/misc/stp/babs/nf-core/singularity/rnaseq/$${NXF_VERSION}/

## BABS-specific stuff
babsfile := $(shell x=`pwd` ;while [ "$$x" != "/" ] ; do  if [ -f "$$x"/.babs ] ; then echo "$$x"/.babs ; break ; else   x=`dirname "$$x"`; fi; done)

ifdef babsfile
babsfield = $(shell sed -n  "s/ *$(1): *//p" $(babsfile))
babsid=$(call babsfield,Hash)
.bp := $(subst /, ,$(call babsfield,Path))
.myname = $(subst @crick.ac.uk,,$(shell $(GIT) config --global user.email))
redirect_outputs = /camp/stp/babs/outputs/$(word 7, $(.bp))/$(word 8,$(.bp))/$(.myname)/$(word 9, $(.bp))
babs_userpath := $(subst /working/bioinformatics/,/working/$(USER)/,$(call babsfield,Path))
redirect_intranet := $(subst /working/,/www/html/internal/users/,$(babs_userpath))
redirect_internet := $(subst /working/,/www/html/external/users/,$(babs_userpath))
babs_type := $(call babsfield, Type)
repo:=https://github.com/BABS-STP/$(babsid)

update-pipeline: ## Update the pipeline
	$(GIT) stash -m "Stashing state prior to pipeline update"
	rsync -avzp $(TEMPLATE_DIR)/$(babs_type)/babs/ .

update-module: ## Update the specific module you're currently using.
	$(GIT) stash -m "Stashing state prior to module update"
	rsync -avzp $(TEMPLATE_DIR)/$(babs_type)/babs/$(notdir $(CURDIR))/ .

dev-pipeline: ## Load development version of whole pipeline
	$(GIT) stash -m "Stashing state prior to pipeline update"
	rsync -avzp $(TEMPLATE_DIR)/dev/$(babs_type)/babs/ .

dev-module: ## Load development version of just the module you're in
	$(GIT) stash -m "Stashing state prior to module update"
	rsync -avzp $(TEMPLATE_DIR)/dev/$(babs_type)/babs/$(notdir $(CURDIR))/ .

endif

update-pm: ## Update the project management scripts
	$(GIT) stash -m "Stashing state prior to updating .github"
	cp -r --no-preserve=mode $(TEMPLATE_DIR)/generic/.github/. ../.github/

