.PHONY: run build copy publish clean
nfcore_dir=.
include shared.mk
include module.mk

configs = $(patsubst %,%.config,$(alignments))
samplesheets = $(patsubst %,samplesheet_%.csv,$(alignments))
plainsheets = $(patsubst %,%.csv,$(alignments))

ifneq (,$(filter-out $(or $(excluded-targets),$(MAKECMDGOALS)),$(MAKECMDGOALS)))
include $(configs)
endif

gene_counts = $(patsubst %,results/%/merged.gene_counts.tsv,$(alignments))

refdir = $(realpath $($*.index_dir)/$($*.genome_fasta_md5)/$($*.gtf_md5))
workdir = $(SCRATCH_DIR)/nf_work

run: $(gene_counts) ## Generate NF-CORE alignments, one folder for each config-specific samplesheet.
	$(GIT) commit -m "Adding files generated by an nfcore run" || echo "No nfcore files needed adding"

$(patsubst %,results/%,$(alignments)):
	mkdir -p $@

$(gene_counts) : results/%/merged.gene_counts.tsv : samplesheet_%.csv  | $(log_dir) $(workdir)
	mkdir -p results/$*
	export NXF_SINGULARITY_CACHEDIR="$(NXF_SINGULARITY_CACHEDIR)" ;\
	export NXF_SINGULARITY_LIBRARYDIR="$(NXF_SINGULARITY_CACHEDIR)" ;\
	export NXF_HOME=$(CURDIR) ;\
	args=();\
	if [ -n "$($*.index_dir)" ];\
	  then if [ -d "$(refdir)" ];\
	    then args+=(--rsem_index=$(refdir)/rsem/  --salmon_index=$(refdir)/salmon/) ;\
	    else  args+=(--save_reference);\
	  fi ;\
	fi ;\
	set -o pipefail ;\
	$(NEXTFLOW) run nf-core/rnaseq \
	--input $< \
	--outdir results/$*/ \
	--aligner $($*.aligner) \
	--fasta $(realpath $($*.genome_fasta)) \
	--gtf $(realpath $($*.gtf)) \
	-w $(workdir) \
	-ansi-log false \
	"$${args[@]}" \
	$(or $($*.nfcore),$(nf_options)) $(call log,nfcore)
	if [ -n "$($*.index_dir)" ] && [ ! -d "$(refdir)" ];\
	    then mkdir -p "$(refdir)" && mv results/$*/genome/index/* "$(refdir)"/;\
	fi
	$(NEXTFLOW) clean -f
	ln -sfn $($*.aligner)/$(subst star_,,$($*.aligner)).merged.gene_counts.tsv $@
	ln -sfn multiqc/$($*.aligner)/ results/$*/multi-qc



field=$(shell sed '/^$$/d; s/^$*./"/;s/=.*/" TEXT/' "$*.config" | paste -sd ',')
insfield=$(shell sed '/^$$/d; s/^$*./"/;s/=.*/"/' "$*.config" | paste -sd ',')
vals=$(shell sed -r '/^$$/d; s/.*=(.*)/"\1"/' "$*.config" | paste -sd ',')


$(samplesheets): samplesheet_%.csv: %.config %.csv
	rm -f '$*.db'
	$(SQLITE) '$*.db' ".import --csv $*.csv fastqs" \
	"ALTER TABLE fastqs ADD COLUMN universal text;" \
	"UPDATE fastqs SET universal='yes';"; \
	$(SQLITE) '$*.db' 'CREATE TABLE config ($(field));' \
	'INSERT INTO config ($(insfield)) VALUES ($(vals));' \
	'CREATE TABLE fastq AS SELECT * FROM fastqs NATURAL JOIN config ;'; \
	$(SQLITE) -header -csv '$*.db' 'SELECT $(samplesheet_id_column) AS sample, fastq_1, fastq_2, strandedness FROM fastq;' > $@
	rm -f '$*.db'
	if [ ! -z "$($*.grep)" ]; then grep $($*.grep) $@ > $@.tmp; mv $@.tmp $@; fi
	$(GIT) add $@

$(workdir):
	mkdir -p $(workdir)

################################################################
#### Bootrap all relevant data from outside
################################################################

build: samplesheets ## Build all necessary inputs: samplesheets for each matching alignment '.config' from 'docs'.

ifneq ($(docs_dir),)
$(docs_dir)/%:
	$(MAKE) --no-print-directory -C $(docs_dir) $*
$(configs): %.config: $(docs_dir)/%.config
	$(MAKE) --no-print-directory -C $(ingress_dir) $*.config
	cp $(ingress_dir)/$*.config $@
	$(GIT) add $@ $<

$(plainsheets) : % : $(docs_dir)/%
	$(MAKE) --no-print-directory -C $(ingress_dir) $*
	cp $(ingress_dir)/$* $@
	$(GIT) add $@ $<

endif



$(log_dir):
	mkdir -p $@

publish: $(pubdir) ## Copy results to final location. Either 'outputs' folder (default), intranet (`make publish location=intranet`) or internet
	for i in $(built_samplesheets); do \
	  mkdir -p "$(pubdir)/$(VERSION)/$$i" ;\
	  cp --no-preserve=mode -r results/"$$i"/star_rsem/*.markdup.sorted.bam "$(pubdir)/$(VERSION)/$$i" ;\
	  cp --no-preserve=mode -r results/"$$i"/star_rsem/*.markdup.sorted.bam.bai "$(pubdir)/$(VERSION)/$$i" ;\
	done
	ln -sfn $(VERSION) $(pubdir)/latest

clean: ## Remove working files from scratch
	rm -rf $(workdir)
	rm -f nf_work

run-clean:

build-clean:  ## Remove files only needed for re-`run`ning. Downstream steps will still work if `run` has already completed.
	rm -f $(samplesheets)


clean-complete: clean-build ## Complete reset. Donwstream steps will no `build` (and perhaps might not even run even if they've already been built.)
	rm -rf results/$(alignments)


