build: run  ##  'build' is deprecated - `make run` is now sufficient.

ifneq ($(docs_dir),)
$(docs_dir)/%:
	$(MAKE) --no-print-directory -C $(docs_dir) $*

$(file.spec): % : $(docs_dir)/%
	$(MAKE) --no-print-directory -C $(docs_dir) $*
	cp $< $@
	$(GIT) add $@
endif

ifneq ($(ingress_dir),)
$(ingress_dir)/%:
	$(MAKE) --no-print-directory -C $(ingress_dir) $*

$(my_metadata).csv: $(ingress_dir)/$(experiment_table).csv | $(dir $(my_metadata))
	$(MAKE) --no-print-directory -C $(ingress_dir) $(experiment_table).csv
	cp $< $@
	$(GIT) add $@
endif


ifneq ($(nfcore_dir),)
$(nfcore_dir)/%:
	$(MAKE)  --no-print-directory -C $(nfcore_dir) $*

$(samplesheets) : $(my_metadata)_%.csv : $(nfcore_dir)/samplesheet_%.csv $(samples_db) $(my_metadata).csv
	$(SQLITE) -header -csv  $(samples_db) --cmd '.import --csv --schema temp $(my_metadata).csv metadata' 'SELECT metadata.* FROM metadata INNER JOIN (SELECT * FROM "fastq_$*" GROUP BY $(samplesheet_id_column)) AS nfcore on metadata.$(metadata_id_column)=nfcore.$(samplesheet_id_column);' > $@
	$(GIT) add $@

$(samples_db): $(nfcore_dir)/$(samples_db) | $(file.spec) $(staging_dir)
	cp $< $@ || echo "No samples database in nfcore directory"
	$(GIT) add makefile module.mk shared.mk project.mk
	$(GIT) commit -m "Add the differential makefiles" || true
	$(GIT) add pre.renv.lock renv/activate.R .Rprofile
	$(GIT) commit -m "Add the vanilla renv setup" || true
	$(GIT) add $(source_dir) R
	$(GIT) commit -m "Add the template scripts and R functions" || true


$(configs): %.config: $(nfcore_dir)/%.config $(my_metadata)_%.csv  $(my_counts_dir)/%
	cp $< $@
	$(GIT) add $@

multiqc_results = $(patsubst $(nfcore_dir)/results/%/multiqc/star_rsem/multiqc_report.html,$\
  $(RESULTS_DIR)/multiqc-%,$\
  $(wildcard $(nfcore_dir)/results/*/multiqc/star_rsem/multiqc_report.html))
# multiqc_report.html has no recipe, but OK to include it as a prereq as it has to exist by definition of multiqc_results
$(multiqc_results) : $(RESULTS_DIR)/multiqc-% : $(nfcore_dir)/results/%/multiqc/star_rsem/multiqc_report.html
	mkdir -p $@
	cp -lr $(nfcore_dir)/results/$*/multiqc/star_rsem $@ || cp -r $(nfcore_dir)/results/$*/multiqc/star_rsem $@


$(genes_results): $(my_counts_dir)/%: $(nfcore_dir)/results/%/star_rsem/rsem.merged.gene_counts.tsv  $(multiqc_results)
	dir=$(if $($*.group-as),$($*.group-as),$*);\
	mkdir -p $(my_counts_dir)/$${dir} ;\
	cp -l $(nfcore_dir)/results/$${dir}/star_rsem/*.genes.results $(my_counts_dir)/$${dir}/ || cp  $(nfcore_dir)/results/$${dir}/star_rsem/*.genes.results $(my_counts_dir)/$${dir}/


endif




################################################################
#### Helper goals
################################################################


$(log_dir) $(dir $(my_metadata)) data $(RESULTS_DIR)/$(VERSION) $(RESULTS_DIR) $(staging_dir)/$(RESULTS_DIR)/$(VERSION) $(staging_dir):
	mkdir -p $@


rocker.Renviron: 
	echo "RENV_PATHS_PREFIX=$(RENV_PATHS_PREFIX)" > $@
	echo "RENV_PATHS_ROOT=$(RENV_PATHS_ROOT)" >> $@
	echo "RENV_PATHS_LIBRARY=renv/library" >> $@
#	echo "RENV_CONFIG_PAK_ENABLED=TRUE" >> $@

R-local: R-$(RVERSION) ## Create a local shell script that will run R (optional, but helpful for interactive analyses)
R-$(RVERSION): $(CONTAINER_IMAGE)
	echo "#!/bin/bash" > $@
	echo 'function R { $(CONTAINER) $(CONTAINER_FLAGS_INTERACTIVE) $(CONTAINER_IMAGE) R' \$$@  " ; }" >> $@
	echo 'function Rscript { $(CONTAINER) $(CONTAINER_FLAGS_INTERACTIVE) $(CONTAINER_IMAGE) Rscript' \$$@  " ; }" >> $@
	echo 'function conshell { $(CONTAINER_SHELL) ; }' >> $@
	echo "[[ "'$$BASH_SOURCE'" == "'$$0'" ]] && R " \$$@ >> $@
	setfacl -m u::rwx $@
	$(call git-ignore,$@)

.PHONY: rstudio
rstudio: ## Open this environment in RStudio
	. $(source_dir)/shell/rstudio-rocker.sh

clean: ## Remove the staging folder and the log directory - these should never contain anything of lasting interest that can't be recreated
	rm -rf $(staging_dir) $(log_dir)
maintainer-clean: clean ## Remove the results and data directories, in addition to staging and logs. The former contain end-results, so only do this if you really want to discard them (e.g. the analysis had a bug in it, and you want to do some housekeeping)
	rm -rf $(RESULTS_DIR) data 

clean-geo:  ## Remove the GEO files from scratch
	rm -f shortcuts/geo
	rm -rf $(SCRATCH_DIR)geo



MAKEFLAGS += --no-builtin-rules

# Originally, shared.mk comes from the parent directory. Copy it here
