## [general]
export SINGULARITYENV_RENV_PATHS_LIBRARY_ROOT=renv/library

## [Institution-wide settings]
{{ "export SINGULARITY_IMAGEDIR=" ~ singularity_imagedir if singularity_imagedir is defined else '#export SINGULARITY_IMAGEDIR="please specify a value"' }}
if [ -n "${GITHUB_PAT}" ]; then
  export SINGULARITYENV_GITHUB_PAT=${GITHUB_PAT}
fi
{{ "export SINGULARITY_MODULE=" ~ singularity_module if singularity_module is defined else '#export SINGULARITY_MODULE="please specify a value"' }}

export FULLNAME="${FULLNAME:-$(getent passwd "$USER" | cut -d':' -f5 | cut -d',' -f1)}"
export SINGULARITYENV_FULLNAME="${FULLNAME}"
export MY_AFFILIATION="[{ref: babs}]"
export SINGULARITYENV_MY_AFFILIATION="${MY_AFFILIATION}"


## [lab settings]

{% if outputs_root is defined -%}
redirect_outputs={{ outputs_dir }}
{%- endif %}

{%- for key, value in linked_dir_prefixes.items() %}
{{ key }}={{ value }}{{ project_path }}
{%- endfor %}

repo=https://github.com/BABS-STP/{{ ID }}

export NXF_SINGULARITY_CACHEDIR=${SINGULARITY_IMAGEDIR}
{{ "export SINGULARITYENV_RENV_PATHS_ROOT=" ~ singularityenv_renv_paths_root if singularityenv_renv_paths_root is defined else '#export SINGULARITYENV_RENV_PATHS_ROOT="please specify a value"' }}
{{ "export SINGULARITYENV_UV_CACHE_DIR=" ~ singularityenv_uv_cache_dir if singularityenv_uv_cache_dir is defined else '#export SINGULARITYENV_UV_CACHE_DIR="please specify a value"' }}
export SINGULARITYENV_UV_LINK_MODE=symlink
{{ "export SCRATCH_DIR=" ~ scratch if scratch is defined else '#export SCRATCH_DIR="please specify a value"' }}
login_node=babs
