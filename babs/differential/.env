# export DOCKER_USERNAME=# needed in case you need to be authenticated to  pull the docker image. Falls back to GITHUB_USERNAME or 'git config --get github.user'
# export DOCKER_PASSWORD=# falls back to ${GITHUB_PAT}. Both of these DOCKER_ vars need to be relevant to the registry (ie ghcr.io usually, hence the github fallback)
