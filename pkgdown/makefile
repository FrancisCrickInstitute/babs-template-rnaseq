.PHONY: makefile
#Custom settings so that shared.mk thinks that this folder is a subdirectory of '../babs'
staging_dir=.
path_to_secret=babs/
source_dir=../babs/differential/resources
include ../babs/shared.mk

.PHONY: site

ifeq ($(SUBMIT),false)
    ifeq ($(CONTAINERED),false)
##    To be executed directly - no need for (further) wrapping in queue/container functionality

site: renv.lock## Create pkgdown site in ./docs
	rm -rf R
	cp -lr ../babs/differential/R .
	sed  -i 's/^Version:.*/Version: $(patsubst v%,%,$(VERSION))/' DESCRIPTION
	$(R) -e 'roxygen2::roxygenise(); pkgdown::build_site()'

gh-pages: site
	git switch gh-pages
	mv docs ../
	git add docs
	git commit -m "Updating docs to those of $(VERSION)"
	git push origin gh-pages
	git switch -

renv.lock: 
	  $(R) -e 'library(renv); init(); renv::install(c("roxygen2", "pkgdown")); renv::snapshot(type="all")'
    else
##   To be executed by container without slurm, so put what 'make' would normally execute in a temporary
##   shell script, and get container to call that script (so it naturally inherits all the command line
##   arguments etc)
site renv.lock: $(optionalRenviron)
	make -n -s $@ SUBMIT=false EXECUTOR=make > $(TMPSCRIPT)_bash 
	$(CONTAINER) $(CONTAINER_FLAGS) $(CONTAINER_IMAGE) bash "$(TMPSCRIPT)_bash" || { echo "$(TMPSCRIPT)_bash failed." $(call log,container) ; exit 1; }
	rm -f $(TMPSCRIPT)_bash
    endif
else
## To be submitted. So generate a slurm script with the usual slurm
## header, to call the script generated by make. Add a container
## prefix as required.

site renv.lock: $(optionalRenviron)
	echo "$$slurm" > $(TMPSCRIPT)_slurm
	make -n -s $@ SUBMIT=false EXECUTOR=make > $(TMPSCRIPT)_slurm.sh
	echo "$(containerPrefix) $(TMPSCRIPT)_slurm.sh" >> $(TMPSCRIPT)_slurm
	echo 'r=$$?' >>  $(TMPSCRIPT)_slurm
	echo '$(notification)' >> $(TMPSCRIPT)_slurm
	$(make_rwx) $(TMPSCRIPT)_slurm
	$(make_rwx) $(TMPSCRIPT)_slurm.sh
	sbatch $(TMPSCRIPT)_slurm 

endif

################################################################
#### Helper goals
################################################################


clean: ## Remove the staging folder and the log directory - these should never contain anything of lasting interest that can't be recreated
	rm -rf R docs man NAMESPACE Renviron.site secret.mk

MAKEFLAGS += --no-builtin-rules
